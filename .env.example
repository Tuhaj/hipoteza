# Copy this file to .env.local (which is gitignored) and fill in the values.
# The deploy scripts (deploy.sh, backend/deploy-backend.sh) source .env.local
# automatically, so you never pass secrets on the command line or commit them.

# --- Site deploy (deploy.sh) ---
HIPOTEZA_BUCKET=              # S3 bucket name that serves the site
HIPOTEZA_DISTRIBUTION_ID=     # CloudFront distribution id (optional; enables invalidation)

# --- Forms backend (backend/deploy-backend.sh + Lambda environment) ---
HIPOTEZA_ALLOW_ORIGIN=https://hipoteza.isy.sh   # CORS origin allowed to POST the forms
HIPOTEZA_NOTIFY_EMAIL=pz@xfaang.com             # where new submissions are emailed (To)
HIPOTEZA_SENDER_EMAIL=                          # verified Brevo sender (From); must be verified in Brevo
SIGNUP_LIST_ID=                                 # Brevo contact list id for signups (optional)
BREVO_API_KEY=                                  # SECRET Brevo API key (starts with xkeysib-). Never commit.
